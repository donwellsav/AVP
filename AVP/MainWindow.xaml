<Window x:Class="AVP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AVP"
        xmlns:vm="clr-namespace:AVP.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        Title="{Binding Title}" Height="450" Width="800">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBox Text="{Binding MediaPath, UpdateSourceTrigger=PropertyChanged}" Width="300" Margin="0,0,0,10" ToolTip="Enter Media Path"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                 <Button Content="Play" Command="{Binding PlayCommand}" Padding="10,5" Margin="5"/>
                 <Button Content="Pause" Command="{Binding PauseCommand}" Padding="10,5" Margin="5"/>
                 <Button Content="Stop" Command="{Binding StopCommand}" Padding="10,5" Margin="5"/>
            </StackPanel>
            <Button Content="Open Video Output" Command="{Binding OpenVideoWindowCommand}" Padding="10,5" Margin="5" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
