<ui:FluentWindow x:Class="AVPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:AVPlayer"
        xmlns:viewmodels="clr-namespace:AVPlayer.ViewModels"
        mc:Ignorable="d"
        Title="AVPlayer" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Background="#121212"
        Foreground="White">

    <Grid Margin="12,42,12,12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250" MinWidth="200"/> <!-- Library -->
            <ColumnDefinition Width="2*" MinWidth="400"/> <!-- Rundown -->
            <ColumnDefinition Width="350" MinWidth="300"/> <!-- Inspector/Transport -->
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Library -->
        <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" Margin="0,0,6,0" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="LIBRARY" FontWeight="Bold" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                <ListBox Grid.Row="1" Background="Transparent" BorderThickness="0" Foreground="White">
                    <ListBoxItem Content="Media Item 1"/>
                    <ListBoxItem Content="Media Item 2"/>
                    <ListBoxItem Content="Media Item 3"/>
                </ListBox>

                <TextBlock Grid.Row="1" Text="Drag &amp; Drop Media Here"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="#555555" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <!-- Center Pane: Rundown -->
        <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Margin="6,0,6,0" Padding="10">
            <Grid>
                 <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="RUNDOWN" FontWeight="Bold" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                <!-- Placeholder for DataGrid -->
                <DataGrid Grid.Row="1" AutoGenerateColumns="False" HeadersVisibility="Column"
                          Background="Transparent" BorderThickness="0" RowBackground="#252525" AlternatingRowBackground="#2A2A2A" Foreground="White">
                     <DataGrid.Columns>
                        <DataGridTextColumn Header="#" Width="40" IsReadOnly="True" Binding="{Binding Id}"/>
                        <DataGridTextColumn Header="State" Width="60" IsReadOnly="True" Binding="{Binding State}"/>
                        <DataGridTextColumn Header="Name" Width="*" IsReadOnly="True" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Duration" Width="80" IsReadOnly="True" Binding="{Binding Duration}"/>
                     </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Right Pane: Inspector & Transport -->
        <Grid Grid.Column="2" Margin="6,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="250"/> <!-- Preview -->
                <RowDefinition Height="*"/> <!-- Inspector -->
                <RowDefinition Height="Auto"/> <!-- Transport -->
            </Grid.RowDefinitions>

            <!-- Preview Monitors -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="Black" Margin="0,0,4,0" CornerRadius="4">
                    <TextBlock Text="PREVIEW" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                <Border Grid.Column="1" Background="Black" Margin="4,0,0,0" CornerRadius="4" BorderBrush="Red" BorderThickness="1">
                     <TextBlock Text="PROGRAM" Foreground="Red" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- Inspector -->
            <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="INSPECTOR" FontWeight="Bold" Foreground="#AAAAAA" Margin="0,0,0,10"/>

                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Filename:" Foreground="#888888" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Clip_001.mp4" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <Separator Background="#333333" Margin="0,10"/>

                    <TextBlock Text="TIMING" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="In Point" FontSize="10" Foreground="#888888"/>
                            <TextBlock Text="00:00:00:00" FontFamily="Consolas" FontSize="14"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Out Point" FontSize="10" Foreground="#888888"/>
                            <TextBlock Text="00:01:30:15" FontFamily="Consolas" FontSize="14"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#333333" Margin="0,10"/>

                    <TextBlock Text="AUDIO" FontWeight="SemiBold" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <Grid Height="100" Background="#111111">
                        <!-- VU Meter Placeholder -->
                        <TextBlock Text="VU METERS" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#333333"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- Transport -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="TAKE" FontSize="24" FontWeight="Bold"
                        Background="#007ACC" Foreground="White" Height="60"
                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                        Cursor="Hand"/>

                <Button Grid.Column="0" Content="stop" Margin="0,0,10,0" Background="#333333" Foreground="White"/>
                <Button Grid.Column="2" Content="next" Margin="10,0,0,0" Background="#333333" Foreground="White"/>
            </Grid>
        </Grid>

    </Grid>
</ui:FluentWindow>
