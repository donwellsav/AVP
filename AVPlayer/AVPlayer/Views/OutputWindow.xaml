<Window x:Class="AVPlayer.Views.OutputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:AVPlayer.Views"
        mc:Ignorable="d"
        Title="Output Window" Height="450" Width="800"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="Black"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid>
        <!-- The Video View using our D3D logic (currently WriteableBitmap) -->
        <views:VideoViewD3D x:Name="MainVideoView" />
    </Grid>
</Window>
